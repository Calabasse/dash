# Copy to  private/rebuild.env  (gitignored) and fill in.
# Used by poll_rebuild.py to reach the dash-rebuild Cloudflare Worker.

# Worker URL printed by `wrangler deploy` (in worker-rebuild/).
WORKER_URL=https://dash-rebuild.YOUR-SUBDOMAIN.workers.dev

# Same secret you set on the Worker with `wrangler secret put POLLER_TOKEN`.
# Generate one:  python3 -c "import secrets; print(secrets.token_urlsafe(32))"
POLLER_TOKEN=replace-with-a-long-random-string
